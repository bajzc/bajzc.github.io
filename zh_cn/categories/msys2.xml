&lt;a id="rest_code_c72cff08d81a4309a4fc6cf3c2975f1d-20" name="rest_code_c72cff08d81a4309a4fc6cf3c2975f1d-20" href="https://bajzc.com/zh_cn/posts/install-gtk4-on-windows/#rest_code_c72cff08d81a4309a4fc6cf3c2975f1d-20"&gt;&lt;/a&gt;
&lt;a id="rest_code_c72cff08d81a4309a4fc6cf3c2975f1d-21" name="rest_code_c72cff08d81a4309a4fc6cf3c2975f1d-21" href="https://bajzc.com/zh_cn/posts/install-gtk4-on-windows/#rest_code_c72cff08d81a4309a4fc6cf3c2975f1d-21"&gt;&lt;/a&gt;&lt;span class="w"&gt;        &lt;/span&gt;&lt;span class="k"&gt;return&lt;/span&gt;&lt;span class="w"&gt; &lt;/span&gt;&lt;span class="n"&gt;status&lt;/span&gt;&lt;span class="p"&gt;;&lt;/span&gt;
&lt;a id="rest_code_c72cff08d81a4309a4fc6cf3c2975f1d-22" name="rest_code_c72cff08d81a4309a4fc6cf3c2975f1d-22" href="https://bajzc.com/zh_cn/posts/install-gtk4-on-windows/#rest_code_c72cff08d81a4309a4fc6cf3c2975f1d-22"&gt;&lt;/a&gt;&lt;span class="p"&gt;}&lt;/span&gt;
&lt;/pre&gt;&lt;/div&gt;
&lt;/blockquote&gt;
&lt;dl&gt;
&lt;dt&gt;дҝқеӯҳеҗҺеӣһеҲ°е‘Ҫд»ӨиЎҢпјҢеҶҚеҲӣе»әдёҖдёӘеҗҚдёә &lt;em&gt;makefile&lt;/em&gt; зҡ„ж–Үд»¶пјҢиҫ“е…Ҙд»ҘдёӢеҶ…е®№пјҡ&lt;/dt&gt;
&lt;dd&gt;&lt;div class="code"&gt;&lt;pre class="code makefile"&gt;&lt;a id="rest_code_dd1dac9cabbc4c509382f3811e2fdd22-1" name="rest_code_dd1dac9cabbc4c509382f3811e2fdd22-1" href="https://bajzc.com/zh_cn/posts/install-gtk4-on-windows/#rest_code_dd1dac9cabbc4c509382f3811e2fdd22-1"&gt;&lt;/a&gt;&lt;span class="nv"&gt;CC&lt;/span&gt;&lt;span class="w"&gt; &lt;/span&gt;&lt;span class="o"&gt;=&lt;/span&gt;&lt;span class="w"&gt; &lt;/span&gt;gcc
&lt;a id="rest_code_dd1dac9cabbc4c509382f3811e2fdd22-2" name="rest_code_dd1dac9cabbc4c509382f3811e2fdd22-2" href="https://bajzc.com/zh_cn/posts/install-gtk4-on-windows/#rest_code_dd1dac9cabbc4c509382f3811e2fdd22-2"&gt;&lt;/a&gt;&lt;span class="nv"&gt;CFLAGS&lt;/span&gt;&lt;span class="w"&gt; &lt;/span&gt;&lt;span class="o"&gt;=&lt;/span&gt;&lt;span class="w"&gt; &lt;/span&gt;-O2&lt;span class="w"&gt; &lt;/span&gt;-Wall
&lt;a id="rest_code_dd1dac9cabbc4c509382f3811e2fdd22-3" name="rest_code_dd1dac9cabbc4c509382f3811e2fdd22-3" href="https://bajzc.com/zh_cn/posts/install-gtk4-on-windows/#rest_code_dd1dac9cabbc4c509382f3811e2fdd22-3"&gt;&lt;/a&gt;&lt;span class="nv"&gt;GTK_CFLAGS&lt;/span&gt;&lt;span class="w"&gt; &lt;/span&gt;&lt;span class="o"&gt;=&lt;/span&gt;&lt;span class="w"&gt; &lt;/span&gt;&lt;span class="sb"&gt;`&lt;/span&gt;pkg-config&lt;span class="w"&gt; &lt;/span&gt;--cflags&lt;span class="w"&gt; &lt;/span&gt;gtk4&lt;span class="sb"&gt;`&lt;/span&gt;
&lt;a id="rest_code_dd1dac9cabbc4c509382f3811e2fdd22-4" name="rest_code_dd1dac9cabbc4c509382f3811e2fdd22-4" href="https://bajzc.com/zh_cn/posts/install-gtk4-on-windows/#rest_code_dd1dac9cabbc4c509382f3811e2fdd22-4"&gt;&lt;/a&gt;&lt;span class="nv"&gt;GTK_LIBS&lt;/span&gt;&lt;span class="w"&gt; &lt;/span&gt;&lt;span class="o"&gt;=&lt;/span&gt;&lt;span class="w"&gt; &lt;/span&gt;&lt;span class="sb"&gt;`&lt;/span&gt;pkg-config&lt;span class="w"&gt; &lt;/span&gt;--libs&lt;span class="w"&gt; &lt;/span&gt;gtk4&lt;span class="sb"&gt;`&lt;/span&gt;
&lt;a id="rest_code_dd1dac9cabbc4c509382f3811e2fdd22-5" name="rest_code_dd1dac9cabbc4c509382f3811e2fdd22-5" href="https://bajzc.com/zh_cn/posts/install-gtk4-on-windows/#rest_code_dd1dac9cabbc4c509382f3811e2fdd22-5"&gt;&lt;/a&gt;
&lt;a id="rest_code_dd1dac9cabbc4c509382f3811e2fdd22-6" name="rest_code_dd1dac9cabbc4c509382f3811e2fdd22-6" href="https://bajzc.com/zh_cn/posts/install-gtk4-on-windows/#rest_code_dd1dac9cabbc4c509382f3811e2fdd22-6"&gt;&lt;/a&gt;&lt;span class="nf"&gt;all&lt;/span&gt;&lt;span class="o"&gt;:&lt;/span&gt;
&lt;a id="rest_code_dd1dac9cabbc4c509382f3811e2fdd22-7" name="rest_code_dd1dac9cabbc4c509382f3811e2fdd22-7" href="https://bajzc.com/zh_cn/posts/install-gtk4-on-windows/#rest_code_dd1dac9cabbc4c509382f3811e2fdd22-7"&gt;&lt;/a&gt;&lt;span class="w"&gt;        &lt;/span&gt;@mkdir&lt;span class="w"&gt; &lt;/span&gt;-p&lt;span class="w"&gt; &lt;/span&gt;./out
&lt;a id="rest_code_dd1dac9cabbc4c509382f3811e2fdd22-8" name="rest_code_dd1dac9cabbc4c509382f3811e2fdd22-8" href="https://bajzc.com/zh_cn/posts/install-gtk4-on-windows/#rest_code_dd1dac9cabbc4c509382f3811e2fdd22-8"&gt;&lt;/a&gt;&lt;span class="w"&gt;        &lt;/span&gt;&lt;span class="k"&gt;$(&lt;/span&gt;CC&lt;span class="k"&gt;)&lt;/span&gt;&lt;span class="w"&gt; &lt;/span&gt;&lt;span class="k"&gt;$(&lt;/span&gt;GTK_CFLAGS&lt;span class="k"&gt;)&lt;/span&gt;&lt;span class="w"&gt; &lt;/span&gt;-o&lt;span class="w"&gt; &lt;/span&gt;./out/demo.exe&lt;span class="w"&gt; &lt;/span&gt;demo.c&lt;span class="w"&gt; &lt;/span&gt;&lt;span class="k"&gt;$(&lt;/span&gt;GTK_LIBS&lt;span class="k"&gt;)&lt;/span&gt;
&lt;/pre&gt;&lt;/div&gt;
&lt;aside class="admonition note"&gt;
&lt;p class="admonition-title"&gt;жіЁи§Ј&lt;/p&gt;
&lt;p&gt;иҝҷйҮҢзҡ„ &lt;code class="docutils literal"&gt;mkdir&lt;/code&gt; еҸҲжҳҜдёҖдёӘеқ‘пјҢе®үиЈ…Msys2еҗҺпјҢеңЁ &lt;em&gt;usr/bin&lt;/em&gt; дёӢдјҡжңүдёҖдёӘmkdir.exeпјҢе®ғжҳҜд»Һlinuxз§»жӨҚжқҘзҡ„пјҢж”ҜжҢҒlinuxзҡ„дёҖдәӣеҸӮж•°гҖӮиҖҢpowersehllзҡ„mkdirеҲҷ`дёҚж”ҜжҢҒеҸӮж•° &amp;lt;&lt;a class="reference external" href="https://learn.microsoft.com/en-us/windows-server/administration/windows-commands/mkdir#syntax"&gt;https://learn.microsoft.com/en-us/windows-server/administration/windows-commands/mkdir#syntax&lt;/a&gt;&amp;gt;`_гҖӮжүҖд»ҘжҲ‘д»¬е°Ҷ &lt;em&gt;C:msys64usrbin&lt;/em&gt; еҠ е…ҘPathгҖӮ&lt;/p&gt;
&lt;p&gt;дҪҶиҝҷеҸҜиғҪеҸҲдјҡйҖ жҲҗдёҖдәӣй—®йўҳпјҢжҜ”еҰӮеңЁ &lt;em&gt;usr/bin&lt;/em&gt; зӣ®еҪ•дёӢеҸҜиғҪдјҡжңү &lt;em&gt;python.exe&lt;/em&gt; пјҢиҝҷе°ұеҸҜиғҪдјҡеҪұе“ҚдҪ дҪҝз”Ё &lt;code class="docutils literal"&gt;pip&lt;/code&gt; е®үиЈ…гҖӮжүҖд»ҘпјҢPATHзҡ„йЎәеәҸеҫҲйҮҚиҰҒпјҢдҪ еҸҜд»Ҙе°Ҷpythonзҡ„ &lt;em&gt;/bin&lt;/em&gt; зӣ®еҪ•ж”ҫеңЁжңҖдёҠйқўгҖӮ&lt;/p&gt;
&lt;/aside&gt;
&lt;/dd&gt;
&lt;/dl&gt;
&lt;p&gt;дҝқеӯҳеҗҺиҝҗиЎҢ &lt;code class="docutils literal"&gt;make&lt;/code&gt; е‘Ҫд»ӨпјҢexeж–Үд»¶е°ұдјҡеҶҚ &lt;em&gt;./out&lt;/em&gt; ж–Үд»¶еӨ№дёӢз”ҹжҲҗгҖӮ&lt;/p&gt;
&lt;blockquote&gt;
&lt;img alt="/images/GTK_hello_world.png" class="align-center" src="https://bajzc.com/images/GTK_hello_world.png"&gt;
&lt;/blockquote&gt;
&lt;/section&gt;
&lt;/section&gt;
&lt;section id="section-2"&gt;
&lt;h3&gt;&lt;a class="toc-backref" href="https://bajzc.com/zh_cn/posts/install-gtk4-on-windows/#toc-entry-7" role="doc-backlink"&gt;жҖ»з»“&lt;/a&gt;&lt;/h3&gt;
&lt;p&gt;еҲ°иҝҷйҮҢпјҢе®үиЈ…е·Із»Ҹеҹәжң¬з»“жқҹдәҶгҖӮеҸҜд»ҘеҸ‘зҺ°еңЁWindowsдёӢе®үиЈ…й…ҚзҪ®CиҜӯиЁҖзҡ„зҺҜеўғзӣёжҜ”LinuxжқҘиҜҙпјҢдҪ“йӘҢдёҠе·®еҫҲеӨҡгҖӮ&lt;/p&gt;
&lt;p&gt;жүҖд»ҘеңЁиҝҷйҮҢжҺЁиҚҗеӨ§е®¶дҪҝз”ЁGentooпјҢе№¶дҪҝз”Ё &lt;code class="docutils literal"&gt;emerge &lt;span class="pre"&gt;-a&lt;/span&gt; &lt;span class="pre"&gt;gui-libs/gtk&lt;/span&gt;&lt;/code&gt; з»Ҳз»“жң¬ж–ҮпјҲ&lt;/p&gt;
&lt;p&gt;еҰӮжһңиҝҳжңүе…¶д»–й—®йўҳпјҢж¬ўиҝҺеңЁжӯӨи®Ёи®әпјҢжңүиғҪеҠӣиҖ…иҮӘиЎҢGoogle(Baidu)гҖӮ&lt;/p&gt;
&lt;p&gt;иҮідәҺдҪҝз”Ё &lt;em&gt;Vcpkg&lt;/em&gt; е®үиЈ…д»ҘеҸҠеҜ№ &lt;em&gt;Vistual Studio&lt;/em&gt; зҡ„ж”ҜжҢҒпјҢд»ҘеҗҺдјҡеҶҚиЎҘе……гҖӮ&lt;/p&gt;
