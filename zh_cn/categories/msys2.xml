&lt;a id="rest_code_c72cff08d81a4309a4fc6cf3c2975f1d-15" name="rest_code_c72cff08d81a4309a4fc6cf3c2975f1d-15" href="https://bajzc.com/zh_cn/posts/install-gtk4-on-windows/#rest_code_c72cff08d81a4309a4fc6cf3c2975f1d-15"&gt;&lt;/a&gt;
&lt;a id="rest_code_c72cff08d81a4309a4fc6cf3c2975f1d-16" name="rest_code_c72cff08d81a4309a4fc6cf3c2975f1d-16" href="https://bajzc.com/zh_cn/posts/install-gtk4-on-windows/#rest_code_c72cff08d81a4309a4fc6cf3c2975f1d-16"&gt;&lt;/a&gt;&lt;span class="w"&gt;        &lt;/span&gt;&lt;span class="n"&gt;app&lt;/span&gt;&lt;span class="w"&gt; &lt;/span&gt;&lt;span class="o"&gt;=&lt;/span&gt;&lt;span class="w"&gt; &lt;/span&gt;&lt;span class="n"&gt;gtk_application_new&lt;/span&gt;&lt;span class="p"&gt;(&lt;/span&gt;&lt;span class="s"&gt;"org.gtk.example"&lt;/span&gt;&lt;span class="p"&gt;,&lt;/span&gt;&lt;span class="w"&gt; &lt;/span&gt;&lt;span class="n"&gt;G_APPLICATION_DEFAULT_FLAGS&lt;/span&gt;&lt;span class="p"&gt;);&lt;/span&gt;
